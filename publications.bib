@article{RN3103,
   author = {Garg, E. and Chen, L. and Nguyen, T. T. T. and Pokhvisneva, I. and Chen, L. M. and Unternaehrer, E. and MacIsaac, J. L. and McEwen, L. M. and Mah, S. M. and Gaudreau, H. and Levitan, R. and Moss, E. and Sokolowski, M. B. and Kennedy, J. L. and Steiner, M. S. and Meaney, M. J. and Holbrook, J. D. and Silveira, P. P. and Karnani, N. and Kobor, M. S. and O'Donnell, K. J. and Mavan Study, Team},
   title = {The early care environment and DNA methylome variation in childhood},
   journal = {Dev Psychopathol},
   volume = {30},
   number = {3},
   pages = {891-903},
   note = {Garg, Elika
Chen, Li
Nguyen, Thao T T
Pokhvisneva, Irina
Chen, Lawrence M
Unternaehrer, Eva
MacIsaac, Julia L
McEwen, Lisa M
