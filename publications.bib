}

@article{RN991,
   author = {Kuchenbauer, F. and Mah, S. M. and Heuser, M. and McPherson, A. and Ruschmann, J. and Rouhi, A. and Berg, T. and Bullinger, L. and Argiropoulos, B. and Morin, R. D. and Lai, D. and Starczynowski, D. T. and Karsan, A. and Eaves, C. J. and Watahiki, A. and Wang, Y. and Aparicio, S. A. and Ganser, A. and Krauter, J. and Dohner, H. and Dohner, K. and Marra, M. A. and Camargo, F. D. and Palmqvist, L. and Buske, C. and Humphries, R. K.},
